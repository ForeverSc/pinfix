{
  "name": "@pinfix/plugin",
  "version": "1.0.3",
  "description": "Visual UI annotation overlay for Claude Code-powered source editing in dev servers.",
  "type": "module",
  "keywords": [
    "ai",
    "claude",
    "claude-code",
    "vite-plugin",
    "webpack-plugin",
    "rspack-plugin",
    "developer-tools",
    "code-editing",
    "hot-reload",
    "react",
    "vue",
    "unplugin",
    "browser-overlay",
    "ai-coding",
    "devtools"
  ],
  "homepage": "https://github.com/ForeverSc/pinfix#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ForeverSc/pinfix",
    "directory": "packages/unplugin"
  },
  "license": "MIT",
  "author": "foreversc",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./vite": {
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./webpack": {
      "import": "./dist/webpack.js",
      "require": "./dist/webpack.cjs"
    },
    "./rspack": {
      "import": "./dist/rspack.js",
      "require": "./dist/rspack.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "node ../../scripts/sync-package-readmes.mjs",
    "postpack": "node ../../scripts/clean-package-readmes.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.160",
    "@babel/core": "^7.26.0",
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@vue/compiler-dom": "^3.5.35",
    "highlight.js": "^11.11.0",
    "magic-string": "^0.30.0",
    "marked": "^18.0.4",
    "unplugin": "^3.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@pinfix/shared": "workspace:*",
    "@types/babel__traverse": "^7.28.0"
  },
  "files": [
    "dist",
    "README.md",
    "README_ZH.md"
  ]
}
